// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============ User & Auth Models ============

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  name              String?
  password          String?
  emailVerified     DateTime?
  image             String?
  avatar            String?
  role              String    @default("student")
  phone             String?
  country           String?
  timezone          String?
  points            Int       @default(0)
  gems              Int       @default(0)
  marketingConsent  Boolean   @default(false)
  onboardingCompleted Boolean @default(false)
  subscriptionStatus String   @default("free")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  courseProgress    UserCourseProgress[]
  orders            Order[]
  createdGames      Game[]    @relation("CreatedGames")
  gameHistory       UserGameHistory[]
  purchasedCourses  UserPurchasedCourse[]
  rewardTransactions RewardTransaction[]
  lessonProgress    UserLessonProgress[]
  activityAttempts  UserActivityAttempt[]
  wrongQuestions    WrongQuestion[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model EmailVerification {
  id         String    @id @default(cuid())
  email      String
  codeHash   String
  purpose    String    @default("register")
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email, purpose, createdAt])
}

// ============ Course Models ============

model Course {
  id              String    @id @default(cuid())
  title           String
  description     String
  price           Float     @default(0)
  isFree          Boolean   @default(false)
  accessLevel     String    @default("public") // public, registered, paid
  category        String
  courseTrack     String    @default("other") // larry-math, ib-big-math, ngss-science, other
  status          String    @default("active") // active, coming-soon, archived
  expectedFeatures String?  // JSON stored as string for coming-soon course feature cards
  difficultyLevel String
  videoUrl        String?
  videoProvider   String?   // youtube, tencent-vod, external
  youtubeVideoId  String?
  tencentVodFileId String?
  stripePriceId   String?
  thumbnailUrl    String?
  duration        Int?
  viewCount       Int       @default(0)
  enrollmentCount Int       @default(0)
  featured        Boolean   @default(false)
  published       Boolean   @default(false)
  gradeLevel      String?   // CCSS Grade Level: G1, G2, G3, G4, G5
  difficulty      String?   // Difficulty Level: Easy, Medium, Hard
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  userProgress    UserCourseProgress[]
  purchasedBy     UserPurchasedCourse[]
  lessons         Lesson[]
  activities      LessonActivity[]
}

model Lesson {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  description String?
  videoUrl    String?
  videoProvider String? // youtube, tencent-vod, external
  youtubeVideoId String?
  tencentVodFileId String?
  order       Int
  duration    Int?
  isPreview   Boolean  @default(false)
  hasPractice  Boolean @default(false)
  hasGame      Boolean @default(false)
  rewardsPoints Int    @default(0)
  rewardsGems   Int    @default(0)
  viewCount   Int      @default(0)
  gradeLevel  String?  // CCSS Grade Level: G1, G2, G3, G4, G5, etc.
  difficulty  String?  // Difficulty Level: Easy, Medium, Hard
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress UserLessonProgress[]
  activities LessonActivity[]
}

model LessonActivity {
  id          String   @id @default(cuid())
  courseId    String
  lessonId    String?
  type        String   // video, quiz, practice, game
  title       String
  description String?
  config      String?  // JSON stored as string for quizzes/games
  provider    String?  // youtube, tencent-vod, internal-game, internal-quiz
  order       Int      @default(0)
  isRequired  Boolean  @default(true)
  rewardsPoints Int    @default(0)
  rewardsGems   Int    @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson Lesson? @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  attempts UserActivityAttempt[]
  wrongQuestions WrongQuestion[]
}

model UserLessonProgress {
  id                  String    @id @default(cuid())
  userId              String
  lessonId            String
  progressPercentage  Float     @default(0)
  lastWatchedPosition Int       @default(0)
  completedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model UserActivityAttempt {
  id          String   @id @default(cuid())
  userId      String
  activityId  String
  score       Int?
  maxScore    Int?
  completed   Boolean  @default(false)
  earnedPoints Int     @default(0)
  earnedGems   Int     @default(0)
  data        String?  // JSON stored as string
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity LessonActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
}

model WrongQuestion {
  id              String   @id @default(cuid())
  userId          String
  activityId      String
  courseId        String?
  lessonId        String?
  questionId      String
  questionType    String
  prompt          String
  choices         String?
  submittedAnswer String?
  correctAnswer   String?
  hint            String?
  explanation     String?
  status          String   @default("open")
  mistakeCount    Int      @default(1)
  lastSeenAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity LessonActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([userId, activityId, questionId])
  @@index([userId, status, updatedAt])
  @@index([courseId, lessonId])
}

model UserCourseProgress {
  id                  String    @id @default(cuid())
  userId              String
  courseId            String
  progressPercentage  Float     @default(0)
  lastWatchedPosition Int       @default(0)
  completedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model UserPurchasedCourse {
  id         String   @id @default(cuid())
  userId     String
  courseId   String
  orderId    String?
  status      String   @default("active")
  source      String   @default("purchase") // purchase, manual, promo
  grantedBy   String?
  purchasedAt DateTime @default(now())
  expiresAt   DateTime?

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  order  Order?  @relation(fields: [orderId], references: [id])

  @@unique([userId, courseId])
}

// ============ Payment & Order Models ============

model Order {
  id            String   @id @default(cuid())
  userId        String
  amount        Float
  currency      String   @default("CNY")
  status        String   @default("pending")
  paymentMethod String?
  paymentId     String?
  items         String   // JSON stored as string for SQLite
  metadata      String?  // JSON stored as string for SQLite
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  purchasedCourses UserPurchasedCourse[]
}

// ============ Game Models ============

model Game {
  id            String    @id @default(cuid())
  title         String
  description   String
  gameType      String
  isAiGenerated Boolean   @default(false)
  createdByUserId String?
  gameConfig    String    // JSON stored as string for SQLite
  thumbnailUrl  String?
  playCount     Int       @default(0)
  viewCount     Int       @default(0)
  published     Boolean   @default(true)
  featured      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  creator      User?             @relation("CreatedGames", fields: [createdByUserId], references: [id], onDelete: SetNull)
  gameHistory  UserGameHistory[]
}

model UserGameHistory {
  id        String   @id @default(cuid())
  userId    String
  gameId    String
  score     Int?
  duration  Int?
  completed Boolean  @default(false)
  data      String?  // JSON stored as string for SQLite
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
}

model RewardTransaction {
  id          String   @id @default(cuid())
  userId      String
  type        String   // points, gems
  amount      Int
  reason      String
  sourceType  String?  // lesson, quiz, game, purchase, manual
  sourceId    String?
  metadata    String?  // JSON stored as string
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============ Shop & Product Models ============

model Product {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Float
  category    String
  imageUrl    String?
  stock       Int      @default(0)
  featured    Boolean  @default(false)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
